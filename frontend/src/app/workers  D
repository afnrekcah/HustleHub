// ─── Job Detail Modal ──────────────────────────────────────────────────────────
function JobModal({
  job,
  onClose,
  onAccept,
}: {
  job: Job;
  onClose: () => void;
  onAccept: (id: number) => void;
}) {
  const [accepting, setAccepting] = useState(false);

  const handleAccept = () => {
    setAccepting(true);
    setTimeout(() => {
      onAccept(job.id);
      onClose();
    }, 1200);
  };

  return (
    <div
      onClick={onClose}
      style={{
        position: "fixed",
        inset: 0,
        background: "#00000066",
        zIndex: 200,
        display: "flex",
        alignItems: "flex-end",
        justifyContent: "center",
        animation: "fadeIn 0.2s ease",
      }}
    >
      <div
        onClick={(e) => e.stopPropagation()}
        style={{
          background: "#fff",
          borderRadius: "24px 24px 0 0",
          padding: "28px 24px 40px",
          width: "100%",
          maxWidth: 540,
          animation: "slideUp 0.3s ease",
          boxShadow: "0 -8px 40px #00000022",
        }}
      >
        {/* Handle */}
        <div style={{ width: 44, height: 4, background: "#E2E7FF", borderRadius: 4, margin: "0 auto 20px" }} />

        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 16 }}>
          <div style={{ flex: 1 }}>
            <h2 style={{ fontSize: 22, fontWeight: 800, color: "#131B2E", marginBottom: 6 }}>{job.title}</h2>
            <p style={{ color: "#444651", fontSize: 13 }}>📍 {job.location} · {job.distance}</p>
          </div>
          <div style={{ textAlign: "right", marginLeft: 12 }}>
            <p style={{ fontWeight: 800, fontSize: 20, color: "#006C49" }}>{formatFCFA(job.price)}</p>
            <p style={{ color: "#757682", fontSize: 11 }}>{job.priceType}</p>
          </div>
        </div>

        <div style={{ display: "flex", gap: 8, flexWrap: "wrap", marginBottom: 20 }}>
          {job.tags.map((t) => (
            <span key={t} style={{ background: "#EAEDFF", color: "#444651", padding: "5px 12px", borderRadius: 20, fontSize: 12, fontWeight: 600 }}>
              {t}
            </span>
          ))}
          {job.urgent && (
            <span style={{ background: "#FFE4E4", color: "#BA1A1A", padding: "5px 12px", borderRadius: 20, fontSize: 12, fontWeight: 700 }}>
              🔴 URGENT
            </span>
          )}
        </div>

        <div style={{ background: "#F2F3FF", borderRadius: 14, padding: 16, marginBottom: 20 }}>
          <p style={{ fontWeight: 700, color: "#00236F", fontSize: 13, marginBottom: 8 }}>📋 Job Details</p>
          <p style={{ color: "#444651", fontSize: 13, lineHeight: 1.7 }}>
            Client needs help with <strong>{job.title.toLowerCase()}</strong> in {job.location}. Payment via Mobile Money upon completion. This job is in the <strong>{job.category}</strong> category.
          </p>
        </div>

        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10, marginBottom: 20 }}>
          {[
            { label: "💰 Payment", value: formatFCFA(job.price) },
            { label: "📍 Distance", value: job.distance },
            { label: "⏱ Est. Duration", value: job.tags.find((t) => t.includes("Hour")) || "Flexible" },
            { label: "💳 Pay Type", value: job.priceType },
          ].map((item) => (
            <div key={item.label} style={{ background: "#FAFAFA", borderRadius: 12, padding: "12px 14px", border: "1px solid #DAE2FD" }}>
              <p style={{ fontSize: 11, color: "#757682", marginBottom: 3 }}>{item.label}</p>
              <p style={{ fontSize: 13, fontWeight: 700, color: "#131B2E" }}>{item.value}</p>
            </div>
          ))}
        </div>

        <button
          onClick={handleAccept}
          disabled={accepting}
          style={{
            width: "100%",
            padding: "15px",
            background: accepting ? "#006C49" : "linear-gradient(135deg, #00236F, #264191)",
            color: "#fff",
            border: "none",
            borderRadius: 14,
            fontSize: 15,
            fontWeight: 700,
            cursor: accepting ? "not-allowed" : "pointer",
            transition: "all 0.3s ease",
            display: "flex",
            alignItems: "center",
            justifyContent: "center",
            gap: 8,
          }}
        >
          {accepting ? "✅ Job Accepted! Notifying client..." : "Accept This Job →"}
        </button>
      </div>
    </div>
  );
}

