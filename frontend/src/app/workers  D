                          background: job.urgent
                            ? "linear-gradient(135deg, #BA1A1A, #991B1B)"
                            : "linear-gradient(135deg, #00236F, #264191)",
                          color: "#fff",
                          border: "none",
                          borderRadius: 12,
                          fontSize: 13,
                          fontWeight: 700,
                          cursor: "pointer",
                          display: "flex",
                          alignItems: "center",
                          justifyContent: "center",
                          gap: 6,
                        }}
                      >
                        {job.urgent ? "⚡ View Urgent Job →" : "View Details →"}
                      </button>
                    )}
                  </div>
                ))}

                {filteredJobs.length === 0 && (
                  <div style={{ textAlign: "center", padding: "40px 20px", color: "#94A3B8" }}>
                    <p style={{ fontSize: 32, marginBottom: 8 }}>🔍</p>
                    <p style={{ fontSize: 14 }}>No jobs in this category right now.</p>
                  </div>
                )}
              </div>
            </div>

            {/* ── RIGHT SIDEBAR ── */}
            <div className="fade-in s2" style={{ display: "flex", flexDirection: "column", gap: 20 }}>

              {/* Upcoming Jobs */}
              <div>
                <h3 style={{ fontSize: 18, fontWeight: 700, marginBottom: 14 }}>Upcoming Jobs</h3>
                <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
                  {upcomingJobs.length === 0 && (
                    <p style={{ color: "#94A3B8", fontSize: 13, textAlign: "center", padding: "20px 0" }}>
                      No upcoming jobs scheduled.
                    </p>
                  )}
                  {upcomingJobs.map((u) => (
                    <div
                      key={u.id}
                      className="upcoming-card"
                      style={{
                        background: "#fff",
                        borderRadius: 14,
                        padding: "14px 16px",
                        borderLeft: `4px solid ${u.color}`,
                        boxShadow: "0 1px 6px #0000000a",
                        display: "flex",
                        justifyContent: "space-between",
                        alignItems: "flex-start",
                        gap: 10,
                      }}
                    >
                      <div style={{ flex: 1 }}>
                        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 4 }}>
                          <span style={{ fontSize: 10, fontWeight: 800, color: u.color, textTransform: "uppercase", letterSpacing: "0.05em" }}>
                            {u.day}, {u.time}
                          </span>
                          <span style={{ fontSize: 16 }}>📅</span>
                        </div>
                        <p style={{ fontWeight: 700, color: "#131B2E", fontSize: 13, marginBottom: 2 }}>
                          {u.icon} {u.title}
                        </p>
                        <p style={{ color: "#757682", fontSize: 11 }}>{u.address}</p>
                      </div>
                      <button
                        className="dismiss-btn"
                        onClick={() => dismissUpcoming(u.id)}
                        style={{ color: "#C5C5D3", fontSize: 16, marginTop: -2 }}
                      >
                        ✕
                      </button>
                    </div>
                  ))}
                </div>
              </div>

              {/* Map placeholder */}
              <div>
                <h3 style={{ fontSize: 18, fontWeight: 700, marginBottom: 14 }}>Job Activity Map</h3>
                <div
                  style={{
                    background: "linear-gradient(135deg, #DAE2FD, #E2E7FF)",
                    borderRadius: 16,
                    height: 180,
                    display: "flex",
                    flexDirection: "column",
                    alignItems: "center",
                    justifyContent: "center",
                    border: "1px solid #C5C5D3",
                    position: "relative",
                    overflow: "hidden",
                  }}
                >
                  {/* Fake map dots */}
                  {[
                    { top: "30%", left: "25%" },
                    { top: "55%", left: "60%" },
                    { top: "20%", left: "70%" },
                    { top: "70%", left: "35%" },
                  ].map((pos, i) => (
                    <div
                      key={i}
                      style={{
                        position: "absolute",
                        top: pos.top,
                        left: pos.left,
                        width: 12,
                        height: 12,
                        borderRadius: "50%",
                        background: "#00236F",
                        border: "2px solid #fff",
                        boxShadow: "0 0 0 4px #00236f33",
                      }}
                    />
                  ))}
                  <div
                    style={{
                      background: "#fff",
                      borderRadius: 20,
                      padding: "8px 16px",
                      display: "flex",
                      alignItems: "center",
                      gap: 8,
                      boxShadow: "0 2px 10px #00000018",
                      zIndex: 1,
                    }}
                  >
                    <span
                      style={{
                        width: 10,
                        height: 10,
                        borderRadius: "50%",
                        background: "#006C49",
                        display: "inline-block",
                        boxShadow: "0 0 0 4px #006c4933",
                        animation: "pulse 1.5s infinite",
                      }}
                    />
                    <span style={{ fontSize: 12, fontWeight: 700, color: "#00236F" }}>
                      Buea · Map View Active
                    </span>
                  </div>
                  <p style={{ fontSize: 11, color: "#444651", marginTop: 8, zIndex: 1 }}>
                    📍 Showing {filteredJobs.length} jobs near you
                  </p>
                </div>
              </div>

              {/* Quick stats */}
              <div
                style={{
                  background: "#fff",
                  borderRadius: 16,
                  padding: 18,
                  border: "1px solid #DAE2FD",
                  boxShadow: "0 1px 6px #0000000a",
                }}
              >
                <p style={{ fontWeight: 700, fontSize: 15, marginBottom: 14 }}>Your Stats</p>
                {[
                  { label: "Jobs Accepted", value: completedJobs, icon: "✅" },
                  { label: "Response Rate", value: "97%", icon: "⚡" },
                  { label: "Repeat Clients", value: "8", icon: "🔁" },
                  { label: "Avg. Rating", value: "4.9 ★", icon: "⭐" },
                ].map((stat) => (
                  <div
                    key={stat.label}
                    style={{
                      display: "flex",
                      justifyContent: "space-between",
                      alignItems: "center",
                      padding: "8px 0",
                      borderBottom: "1px solid #F1F5F9",
                    }}
                  >
                    <span style={{ fontSize: 13, color: "#444651" }}>
                      {stat.icon} {stat.label}
                    </span>
                    <span style={{ fontSize: 14, fontWeight: 700, color: "#00236F" }}>{stat.value}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </main>

      {/* ── FOOTER ─────────────────────────────────────────────────────────── */}
      <footer
        style={{
          background: "#fff",
          borderTop: "1px solid #DAE2FD",
          padding: "28px 20px",
          marginTop: 48,
          marginBottom: 80,
        }}
      >
        <div
          style={{
            maxWidth: 1200,
            margin: "0 auto",
            display: "flex",
            flexWrap: "wrap",
            justifyContent: "space-between",
            alignItems: "center",
            gap: 12,
          }}
        >
          <div>
            <p style={{ fontWeight: 800, fontSize: 17, color: "#00236F" }}>HustleHub</p>
            <p style={{ color: "#757682", fontSize: 12, marginTop: 2 }}>
              © 2026 HustleHub Marketplace. Supporting student ambition.
            </p>
          </div>
          <div style={{ display: "flex", gap: 22, flexWrap: "wrap" }}>
            {["Terms of Service", "Privacy Policy", "Support"].map((t) => (
              <a
                key={t}
                href="#"
                style={{ color: "#444651", fontSize: 13, textDecoration: "none" }}
              >
                {t}
              </a>
            ))}
          </div>
        </div>
      </footer>

      {/* ── BOTTOM NAV ─────────────────────────────────────────────────────── */}
      <nav
        style={{
          position: "fixed",
          bottom: 0,
          left: 0,
          width: "100%",
          height: 76,
          background: "#fff",
          borderTop: "1px solid #DAE2FD",
          display: "flex",
          justifyContent: "space-around",
          alignItems: "center",
          boxShadow: "0 -2px 12px #0000000d",
          borderRadius: "16px 16px 0 0",
          zIndex: 99,
        }}
      >
        {[
          { label: "Home", icon: "🏠" },
          { label: "My Jobs", icon: "💼" },
          { label: "Post Job", icon: "➕" },
          { label: "Profile", icon: "👤" },
        ].map((item) => (
          <button
            key={item.label}
            className="nav-item"
            onClick={() => setActiveNav(item.label)}
            style={{
              display: "flex",
              flexDirection: "column",
              alignItems: "center",
              gap: 3,
              color: activeNav === item.label ? "#00236F" : "#94969E",
              fontWeight: activeNav === item.label ? 800 : 500,
              transform: activeNav === item.label ? "scale(1.1)" : "scale(1)",
              fontSize: 12,
              fontFamily: "inherit",
            }}
          >
            <span style={{ fontSize: 22 }}>{item.icon}</span>
            {item.label}
          </button>
        ))}
      </nav>

      {/* ── FAB ─────────────────────────────────────────────────────────────── */}
      <button
        className="fab"
        style={{
          position: "fixed",
          bottom: 96,
          right: 24,
          width: 56,
          height: 56,
          borderRadius: "50%",
          background: "#00236F",
          color: "#fff",
          border: "none",
          fontSize: 24,
          boxShadow: "0 8px 24px #00236f44",
          cursor: "pointer",
          zIndex: 98,
        }}
      >
        💬
      </button>

      {/* ── JOB DETAIL MODAL ─────────────────────────────────────────────── */}
      {selectedJob && (
        <JobModal
          job={selectedJob}
          onClose={() => setSelectedJob(null)}
          onAccept={handleAccept}
        />
      )}

      {/* Responsive sidebar fix */}
      <style>{`
        @media (max-width: 768px) {
          .main-grid {
            grid-template-columns: 1fr !important;
          }
        }
      `}</style>
    </div>
  );
}